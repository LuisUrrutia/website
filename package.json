{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "build:preview": "rm -rf dist; astro build && astro preview",
    "dev": "astro dev",
    "fmt": "prettier . --check",
    "fmt:fix": "prettier . --write",
    "lint": "oxlint --type-aware",
    "prepare": "husky",
    "preview": "astro preview"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "*.{js,ts,jsx,tsx,astro}": "oxlint --type-aware"
  },
  "overrides": {
    "lodash": "4.17.23",
    "yaml": "2.8.3"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@playform/compress": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.7",
    "astro-font": "^1.1.0",
    "astro-og-canvas": "^0.11.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@prettier/plugin-oxc": "0.1.4",
    "astro-compressor": "^1.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=22.12.0"
  },
  "x-securityOverrideNotes": {
    "lodash": "CVE-2025-13465 - remove when @astrojs/check updates yaml-language-server",
    "yaml": "Force a patched yaml version because yaml-language-server still pins 2.7.1"
  }
}
